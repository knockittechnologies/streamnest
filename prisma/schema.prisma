// StreamNest data model
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())

  favorites     Favorite[]
  watchHistory  WatchHistory[]
  settings      UserSettings?
  recentSearches RecentSearch[]
}

model Channel {
  id            String   @id @default(cuid())
  name          String
  category      String
  channelNumber Int      @unique @default(autoincrement())
  streamUrl     String?  // .m3u8 / .mp4 → <video>, anything else → <iframe>
  colorFrom     String   @default("#C9A25D")
  colorTo       String   @default("#6FE3D6")
  isLive        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  favorites     Favorite[]
  watchHistory  WatchHistory[]

  @@index([category])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

model WatchHistory {
  id             String   @id @default(cuid())
  userId         String
  channelId      String
  progress       Int      @default(0) // 0-100, used for "Continue Watching"
  lastWatchedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId, lastWatchedAt])
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  theme         String  @default("dark")   // dark | light
  accent        String  @default("bronze") // bronze | crimson | emerald | plum
  layout        String  @default("grid")   // grid | list
  startupPage   String  @default("home")   // home | livetv | favorites
  language      String  @default("English")
  autoplayNext  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecentSearch {
  id        String   @id @default(cuid())
  userId    String
  term      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
